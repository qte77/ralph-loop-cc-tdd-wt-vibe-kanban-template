# Claude Code API key (required)
ANTHROPIC_API_KEY=sk-ant-...

# Ralph Loop model routing (optional, defaults shown)
# RALPH_DEFAULT_MODEL=sonnet
# RALPH_FIX_MODEL=haiku
# RALPH_SIMPLE_MODEL=haiku
# RALPH_JUDGE_MODEL=sonnet

# Ralph execution parameters (optional, defaults shown)
# RALPH_MAX_ITERATIONS=25
# RALPH_MAX_FIX_ATTEMPTS=3
# RALPH_VALIDATION_TIMEOUT=300
# RALPH_FIX_TIMEOUT=300

# Judge mode (optional, for multi-worktree)
# RALPH_JUDGE_ENABLED=false
# RALPH_SECURITY_REVIEW=false

# Vibe Kanban port (optional)
# RALPH_VIBE_PORT=5173
