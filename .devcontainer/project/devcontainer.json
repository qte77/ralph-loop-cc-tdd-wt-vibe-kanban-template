{
  "name": "Project DevEnv",
  "image": "mcr.microsoft.com/vscode/devcontainers/python:3.13",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {},
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "moby": false
    }
  },
  "containerEnv": {
    "UV_LINK_MODE": "copy"
  },
  "remoteEnv": {
    "LOAD_DOTENV": "true",
    "UV_CACHE_DIR": "/tmp/claude-1000/uv-cache"
  },
  "postCreateCommand": "make setup_sandbox && make setup_dev",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "mhutchie.git-graph",
        "DavidAnson.vscode-markdownlint",
        "tamasfe.even-better-toml"
      ]
    }
  }
}
